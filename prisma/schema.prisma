generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  clerkUserId        String              @unique
  email              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  brands             BrandProfile[]
  projects           EmailProject[]
  globalChatMessages GlobalChatMessage[]
}

model BrandProfile {
  id            String         @id @default(cuid())
  userId        String
  name          String
  websiteUrl    String?
  logoUrl       String?
  primaryColor  String         @default("#0f766e")
  accentColor   String         @default("#111827")
  fontPreset    String         @default("Inter")
  voiceNotes    String         @default("Clear, polished, and conversion-focused.")
  defaultFooter String         @default("You are receiving this because you signed up for updates.")
  senderName    String         @default("Commerce Team")
  senderEmail   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      EmailProject[]

  @@index([userId])
}

model EmailProject {
  id             String         @id @default(cuid())
  userId         String
  brandProfileId String?
  title          String
  templateId     String
  subject        String
  previewText    String
  editorDocument Json
  renderedHtml   String?
  renderedText   String?
  sections       Json
  version        Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandProfile   BrandProfile?  @relation(fields: [brandProfileId], references: [id], onDelete: SetNull)
  chatMessages   ChatMessage[]
  patchEvents    PatchEvent[]

  @@index([userId])
  @@index([brandProfileId])
}

model ChatMessage {
  id        String       @id @default(cuid())
  projectId String
  role      String
  message   Json
  createdAt DateTime     @default(now())
  project   EmailProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PatchEvent {
  id              String       @id @default(cuid())
  projectId       String
  previousVersion Int
  nextVersion     Int
  patches         Json
  summary         String
  source          String
  createdAt       DateTime     @default(now())
  project         EmailProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model GlobalChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  message   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
